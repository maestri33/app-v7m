# Contrato de env do front (server-side, NÃO exposto ao client).
#
# Único valor que muda entre ambientes: o endereço do backend Django+Ninja.
# Em dev o Django roda na porta 80 do host; em prod é o domínio público.

# DEV (Django local na 80 deste host)
# BACKEND_URL=http://localhost:80

# PROD
BACKEND_URL=https://backend.v7m.live

# NODE_ENV=production é setado pelo runtime (`node server.js`); com BACKEND_URL
# https, os cookies de sessão saem com `Secure` (lib/auth/cookies.ts).
